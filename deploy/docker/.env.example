# Copy to .env and customize

# For controller (deploy/docker/docker-compose.yml) — optional, only used on first startup
# KRONFORCE_BOOTSTRAP_ADMIN_KEY=kf_your_admin_key
# KRONFORCE_BOOTSTRAP_AGENT_KEY=kf_your_agent_key

# For agent (deploy/docker/docker-compose.agent.yml) — required
# KRONFORCE_CONTROLLER_URL=http://your-controller:8080
# KRONFORCE_AGENT_KEY=kf_your_agent_key
# KRONFORCE_AGENT_NAME=my-agent
# KRONFORCE_AGENT_TAGS=linux,prod

# For full stack (deploy/docker/docker-compose.full.yml) — optional, auto-generated if omitted
# Keys are saved to /data/bootstrap-keys.txt on first startup
# KRONFORCE_ADMIN_KEY=kf_my_admin_key
# KRONFORCE_AGENT_KEY=kf_my_agent_key
