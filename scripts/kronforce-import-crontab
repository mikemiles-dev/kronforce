#!/usr/bin/env python3
"""
Import crontab entries into Kronforce as scheduled jobs.

Reads crontab format from stdin and creates a Kronforce job for each entry.
Standard 5-field cron expressions are converted to 6-field (seconds prepended).

Usage:
    crontab -l | kronforce-import-crontab kf_your_admin_key
    kronforce-import-crontab kf_your_admin_key < /etc/cron.d/my-jobs
    kronforce-import-crontab kf_your_admin_key --group Monitoring
    KRONFORCE_URL=http://host:8080 kronforce-import-crontab kf_your_key

Options:
    --group NAME    Assign imported jobs to this group (default: Imported)
    --dry-run       Show what would be created without making API calls
    --prefix NAME   Prefix job names with this string (default: none)
"""

import json
import os
import re
import sys

URL = os.environ.get("KRONFORCE_URL", "http://localhost:8080")


def parse_crontab_line(line):
    """Parse a crontab line into (cron_expr, command) or None."""
    line = line.strip()
    if not line or line.startswith("#"):
        return None
    # Skip variable assignments (KEY=VALUE)
    if re.match(r"^[A-Za-z_][A-Za-z0-9_]*=", line):
        return None
    # Skip special entries like @reboot
    if line.startswith("@"):
        keyword, _, command = line.partition(" ")
        keyword = keyword.strip().lower()
        command = command.strip()
        if not command:
            return None
        cron_map = {
            "@yearly": "0 0 0 1 1 *",
            "@annually": "0 0 0 1 1 *",
            "@monthly": "0 0 0 1 * *",
            "@weekly": "0 0 0 * * 0",
            "@daily": "0 0 0 * * *",
            "@midnight": "0 0 0 * * *",
            "@hourly": "0 0 * * * *",
        }
        if keyword in cron_map:
            return cron_map[keyword], command
        # @reboot and others not supported
        return None

    # Standard 5-field cron
    parts = line.split(None, 5)
    if len(parts) < 6:
        return None
    cron_5 = " ".join(parts[:5])
    command = parts[5]
    # Convert 5-field to 6-field by prepending seconds=0
    cron_6 = "0 " + cron_5
    return cron_6, command


def make_job_name(command, prefix=""):
    """Generate a job name from a command."""
    # Use the base command name
    cmd = command.split()[0] if command.split() else "job"
    # Strip path
    name = os.path.basename(cmd)
    # Remove extension
    name = re.sub(r"\.(sh|py|rb|pl|bash)$", "", name)
    # Clean up
    name = re.sub(r"[^a-zA-Z0-9_-]", "-", name)
    name = re.sub(r"-+", "-", name).strip("-")
    if not name:
        name = "imported-job"
    if prefix:
        name = f"{prefix}-{name}"
    return name[:60]


def create_job(api_key, name, command, cron_expr, group):
    """Create a job via the Kronforce API."""
    import urllib.request
    import urllib.error

    body = json.dumps({
        "name": name,
        "task": {"type": "shell", "command": command},
        "schedule": {"type": "cron", "value": cron_expr},
        "group": group,
    }).encode()

    req = urllib.request.Request(
        f"{URL}/api/jobs",
        data=body,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req) as resp:
            return True, json.loads(resp.read())
    except urllib.error.HTTPError as e:
        error_body = e.read().decode() if e.fp else str(e)
        return False, error_body


def main():
    args = sys.argv[1:]

    # Parse flags
    group = "Imported"
    dry_run = False
    prefix = ""
    api_key = None

    i = 0
    while i < len(args):
        if args[i] == "--group" and i + 1 < len(args):
            group = args[i + 1]
            i += 2
        elif args[i] == "--dry-run":
            dry_run = True
            i += 1
        elif args[i] == "--prefix" and i + 1 < len(args):
            prefix = args[i + 1]
            i += 2
        elif args[i] == "--help" or args[i] == "-h":
            print(__doc__.strip())
            sys.exit(0)
        elif not args[i].startswith("--") and api_key is None:
            api_key = args[i]
            i += 1
        else:
            print(f"Unknown argument: {args[i]}", file=sys.stderr)
            sys.exit(1)

    if not api_key and not dry_run:
        print("Usage: kronforce-import-crontab <api-key> [--group NAME] [--dry-run] [--prefix NAME]")
        print()
        print("Reads crontab from stdin. Pipe with: crontab -l | kronforce-import-crontab kf_key")
        sys.exit(1)

    if sys.stdin.isatty():
        print("Reading crontab from stdin (pipe or redirect a file)...")
        print("Example: crontab -l | kronforce-import-crontab kf_your_key")
        sys.exit(1)

    lines = sys.stdin.readlines()
    entries = []
    used_names = set()

    for line in lines:
        parsed = parse_crontab_line(line)
        if parsed is None:
            continue
        cron_expr, command = parsed
        name = make_job_name(command, prefix)
        # Deduplicate names
        base_name = name
        counter = 1
        while name in used_names:
            name = f"{base_name}-{counter}"
            counter += 1
        used_names.add(name)
        entries.append((name, command, cron_expr))

    if not entries:
        print("No cron entries found in input.")
        sys.exit(0)

    print(f"Found {len(entries)} cron entries")
    print(f"Target: {URL}")
    print(f"Group: {group}")
    print()

    created = 0
    failed = 0

    for name, command, cron_expr in entries:
        if dry_run:
            print(f"  [dry-run] {name}")
            print(f"            schedule: {cron_expr}")
            print(f"            command:  {command[:80]}{'...' if len(command) > 80 else ''}")
            created += 1
        else:
            ok, result = create_job(api_key, name, command, cron_expr, group)
            if ok:
                print(f"  + {name}")
                created += 1
            else:
                print(f"  ! {name} — {result}")
                failed += 1

    print()
    print(f"{'Would create' if dry_run else 'Created'}: {created}")
    if failed:
        print(f"Failed: {failed}")
    if not dry_run and created > 0:
        print(f"\nOpen {URL} to see your imported jobs.")


if __name__ == "__main__":
    main()
